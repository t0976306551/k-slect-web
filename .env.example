# K-slect 環境變數範本
# 複製此檔案為 .env 並填入實際值
# cp .env.example .env
#
# 注意：.env 已加入 .gitignore，絕對不能提交到 git

# ===== 資料庫 =====
# Railway PostgreSQL 連線字串
# 取得方式：Railway Dashboard > 你的 PostgreSQL 服務 > Connect > DATABASE_URL
DATABASE_URL=postgresql://user:password@host:port/dbname

# ===== Next.js =====
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# ===== 應用程式 =====
NODE_ENV=development

# ===== Facebook Graph API =====
# 取得方式：https://developers.facebook.com > 建立 App > 設定 > 基本資料
# App 類型：商業 (Business)
# 需要的權限：pages_manage_posts, pages_read_engagement, pages_show_list
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
# 用於伺服器端呼叫 Graph API（不需要用戶授權的操作）
# 格式：{app-id}|{app-secret}
FACEBOOK_APP_ACCESS_TOKEN=your-app-id|your-app-secret

# ===== LINE Messaging API =====
# 取得方式：https://developers.line.biz > LINE Official Account > Messaging API
# 需要先在 LINE Official Account Manager 建立官方帳號
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret

# ===== UTM 追蹤 =====
# 網站正式網域（用於產生 UTM 連結）
NEXT_PUBLIC_SITE_URL=https://k-slect.com
