# K-slect 前台環境變數範本
# 複製此檔案為 .env 並填入實際值
# cp .env.example .env
#
# 注意：.env 已加入 .gitignore，絕對不能提交到 git

# ── 後端連接 ───────────────────────────────────────────────────────────────
# k-slect-backend 的 API 基底 URL
BACKEND_URL=http://localhost:3001/api
# 後端管理員帳號密碼（用於 Next.js 自動刷新 service token）
# token 過期時，系統會自動以此帳密重新取得新 token，不需手動更新
BACKEND_ADMIN_EMAIL=admin@k-slect.com
BACKEND_ADMIN_PASSWORD=your-admin-password-here
# 初始 service token（可選，留空時啟動後第一次請求會自動登入取得）
BACKEND_SERVICE_TOKEN=

# ── SSR Absolute URL ───────────────────────────────────────────────────────
# Server Component fetch 需要絕對路徑，填入前台實際執行的 URL
NEXTAUTH_URL=http://localhost:7432
NEXT_PUBLIC_SITE_URL=http://localhost:7432

# ── Mock 模式 ──────────────────────────────────────────────────────────────
# 開發時不啟動後端可設 true，使用內建假資料
NEXT_PUBLIC_USE_MOCK=false

# ── 商家銀行資訊（顯示在結帳頁）──────────────────────────────────────────
NEXT_PUBLIC_MERCHANT_BANK_NAME=玉山銀行
NEXT_PUBLIC_MERCHANT_BANK_CODE=808
NEXT_PUBLIC_MERCHANT_BANK_BRANCH=板橋分行
NEXT_PUBLIC_MERCHANT_BANK_ACCOUNT_NAME=K-slect 國際貿易股份有限公司
NEXT_PUBLIC_MERCHANT_BANK_ACCOUNT_NUMBER=1234-5678-9012
# 付款期限（小時），超過此時間訂單將自動取消
NEXT_PUBLIC_MERCHANT_PAYMENT_DEADLINE_HOURS=24

# ── Claude AI（行銷文案生成，選填）────────────────────────────────────────
# 取得方式：https://console.anthropic.com > API Keys
ANTHROPIC_API_KEY=

# ── LINE Messaging API（選填）─────────────────────────────────────────────
# LINE_CHANNEL_ACCESS_TOKEN：用於後端廣播推播訊息
# NEXT_PUBLIC_LINE_OA_ID：用於前台「透過 LINE 聯絡」按鈕，留空則 fallback 到 line.me
LINE_CHANNEL_ACCESS_TOKEN=
NEXT_PUBLIC_LINE_OA_ID=

# ── Facebook（選填）───────────────────────────────────────────────────────
# 取得方式：https://developers.facebook.com > 建立 App > 設定 > 基本資料
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# ── Cron Job 保護金鑰（選填）──────────────────────────────────────────────
# 保護 /api/v1/cron/send-promotions 端點，建議：openssl rand -hex 32
CRON_SECRET=
