# K-slect 環境變數範本
# 複製此檔案為 .env 並填入實際值
# cp .env.example .env
#
# 注意：.env 已加入 .gitignore，絕對不能提交到 git

# ===== 資料庫 =====
# Railway PostgreSQL 連線字串
# 取得方式：Railway Dashboard > 你的 PostgreSQL 服務 > Connect > DATABASE_URL
DATABASE_URL=postgresql://user:password@host:port/dbname

# ===== Next.js =====
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# ===== 應用程式 =====
NODE_ENV=development

# ===== Facebook Graph API =====
# 取得方式：https://developers.facebook.com > 建立 App > 設定 > 基本資料
# App 類型：商業 (Business)
# 需要的權限：pages_manage_posts, pages_read_engagement, pages_show_list
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
# 用於伺服器端呼叫 Graph API（不需要用戶授權的操作）
# 格式：{app-id}|{app-secret}
FACEBOOK_APP_ACCESS_TOKEN=your-app-id|your-app-secret

# ===== LINE Messaging API =====
# 取得方式：https://developers.line.biz > LINE Official Account > Messaging API
# 需要先在 LINE Official Account Manager 建立官方帳號
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret

# ===== UTM 追蹤 =====
# 網站正式網域（用於產生 UTM 連結）
NEXT_PUBLIC_SITE_URL=https://k-slect.com

# ===== AI 文案生成（Claude）=====
# 取得方式：https://console.anthropic.com > API Keys
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# ===== Cron Job 保護 =====
# 隨機字串，用於保護 /api/v1/cron/send-promotions 端點
# 建議：openssl rand -hex 32
CRON_SECRET=your-random-cron-secret-here

# ===== Facebook 粉絲專頁（發文用）=====
# 粉絲專頁 ID（在粉絲專頁「關於」中取得）
FACEBOOK_PAGE_ID=your-facebook-page-id
# 粉絲專頁長效 Access Token（需 pages_manage_posts 權限）
FACEBOOK_PAGE_ACCESS_TOKEN=your-page-long-lived-access-token

# ===== k-slect-backend 後端服務 =====
# 後端 API 基底 URL（預設 http://localhost:3001/api）
BACKEND_URL=http://localhost:3001/api
# 後端管理員帳號密碼（用於 Next.js 自動刷新 service token）
# token 過期時，系統會自動以此帳密重新取得新 token，不需手動更新
BACKEND_ADMIN_EMAIL=admin@k-slect.com
BACKEND_ADMIN_PASSWORD=your-admin-password-here
# 初始 service token（可選）
# 若留空，啟動後第一次 admin 請求會先呼叫登入取得 token
BACKEND_SERVICE_TOKEN=
