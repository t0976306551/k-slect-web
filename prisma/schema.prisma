generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  Product[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Product {
  id          String           @id @default(cuid())
  name        String
  slug        String?          @unique // kebab-case，SEO URL 用
  description String?
  price       Int              // 台幣元，避免浮點數誤差
  originalPrice Int?           // 原價（劃線價），用於顯示折扣
  images      String[]                       // 商品圖片 URL 陣列（TypeORM 端 jsonb，nullable；Prisma 不支援 optional array，實際可為 null）
  externalUrl String?                        // 商品外部連結（韓國原頁）
  origin      String?                        // 產地（如 "韓國"）
  status      String           @default("active") // active | inactive
  categoryId  String
  category    Category         @relation(fields: [categoryId], references: [id])
  inventory   Inventory?
  orderItems  OrderItem[]
  options     ProductOption[]
  variants    ProductVariant[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

// 商品級庫存（無規格的簡單商品用此表）
// 有規格時庫存直接存在 ProductVariant.quantity / lowStockThreshold，不使用此表
model Inventory {
  id                String   @id @default(cuid())
  productId         String   @unique
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku               String   @unique
  quantity          Int      @default(0)
  lowStockThreshold Int      @default(5)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("inventories")
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  address   String?
  tags      String[] @default([])
  note      String?
  status    String   @default("active") // active | inactive | blacklisted | vip
  orders    Order[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id                       String      @id @default(cuid())
  orderNo                  String      @unique @default(cuid())
  customerId               String
  customer                 Customer    @relation(fields: [customerId], references: [id])
  customerName             String      @default("")
  customerEmail            String      @default("")
  customerPhone            String      @default("")
  shippingAddress          String      @default("")
  trackingNo               String?
  cvsBrand                 String?
  cvsStoreCode             String?
  cvsPickupCode            String?
  cvsStoreName             String?
  cvsStoreAddress          String?
  shippingMethod           String?     // cvs_pickup | home_delivery
  shippingProvider         String?     // seven_eleven | family_mart | black_cat
  totalAmount              Int         // 台幣元
  paymentMethod            String      // bank_transfer | seller_ship
  paymentStatus            String      @default("pending") // pending | paid | failed
  bankTransferInfoSnapshot Json?
  bankTransferReport       Json?
  paymentDueAt             DateTime?
  paidAt                   DateTime?
  status                   String      @default("pending_ship") // pending_ship | shipped | completed | cancelled | refund_pending | refunded
  note                     String?
  items                    OrderItem[]
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
}

model OrderItem {
  id              String          @id @default(cuid())
  orderId         String
  order           Order           @relation(fields: [orderId], references: [id])
  productId       String?         // nullable：商品刪除後仍保留訂單紀錄
  product         Product?        @relation(fields: [productId], references: [id])
  productName     String          // 下單時商品名稱快照
  sku             String          // 下單時 SKU 快照
  image           String?         // 下單時商品圖片快照
  variantSnapshot Json?           // {"顏色":"紅色","尺寸":"M"}
  quantity        Int
  priceAtOrder    Int             // 下單當下價格快照
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model ProductOption {
  id        String               @id @default(cuid())
  productId String
  product   Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String               // "顏色" | "尺寸"
  position  Int                  @default(0)
  values    ProductOptionValue[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@index([productId])
}

model ProductOptionValue {
  id                  String               @id @default(cuid())
  optionId            String
  option              ProductOption        @relation(fields: [optionId], references: [id], onDelete: Cascade)
  value               String               // "紅" | "S"
  position            Int                  @default(0)
  variantOptionValues VariantOptionValue[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([optionId])
}

model ProductVariant {
  id                  String               @id @default(cuid())
  productId           String
  product             Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku                 String               @unique
  price               Int?                 // null = 沿用 Product.price
  image               String?
  quantity            Int                  @default(0)
  lowStockThreshold   Int                  @default(5)
  status              String               @default("active")
  variantOptionValues VariantOptionValue[] // TypeORM 端：variant.optionValues（直接存取 ProductOptionValue[]）
  orderItems          OrderItem[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([productId])
}

// TypeORM 端使用 @ManyToMany @JoinTable({ name: "variant_option_values" })
// variant.optionValues 直接回傳 ProductOptionValue[]，不透過此 join model
model VariantOptionValue {
  variantId     String
  optionValueId String
  variant       ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValue   ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@id([variantId, optionValueId])
  @@index([optionValueId])
  @@map("variant_option_values")
}

// ⚠️ 此 model 為 Prisma 側歷史 schema，TypeORM 後端用 "promotions" table（小寫）
// TypeORM 版本差異：productIds 改為 ManyToMany (promotion_products join table)；無 sendStatus、aiGeneratedCopy
model Promotion {
  id          String    @id @default(cuid())
  channel     String    // LINE | FB（向後相容）
  platform    String    @default("LINE") // line | facebook | both
  message     String    // 推廣訊息文案
  utmUrl      String?   // 附帶 UTM 的追蹤連結
  status      String    @default("draft") // draft | scheduled | sent | failed
  scheduledAt DateTime? // 排程發送時間
  sentAt      DateTime? // 實際發送時間
  metadata    Json?     // 擴充欄位（FB post ID、retry_count、last_error 等）
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, scheduledAt])
}
